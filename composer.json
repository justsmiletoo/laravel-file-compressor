{
    "name": "justsmiletoo/laravel-file-compressor",
    "description": "Automatically compress images, PDFs and videos on upload in Laravel. Auto-detects MIME type and applies the right compressor with zero configuration.",
    "keywords": [
        "laravel",
        "compression",
        "image",
        "pdf",
        "video",
        "resize",
        "optimize",
        "ffmpeg",
        "ghostscript",
        "upload"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "sididev",
            "email": "sidimariko61@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "intervention/image": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "JustSmileToo\\FileCompressor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JustSmileToo\\FileCompressor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JustSmileToo\\FileCompressor\\FileCompressorServiceProvider"
            ],
            "aliases": {
                "FileCompressor": "JustSmileToo\\FileCompressor\\Facades\\FileCompressor"
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
